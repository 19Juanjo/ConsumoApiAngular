{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**"
        ]
      }
    }
  ],
  "dataGroups": [
  {
    "name": "characters-cache",
    "urls": [
      "https://api.tvmaze.com/shows/169/cast"
    ],
    "cacheConfig": {
      "strategy": "performance",
      "maxSize": 20,
      "maxAge": "1d"
    }
  }
]
}